# Phoenix AI Gauntlet — Environment Variables

# Server port (default: 3000)
PORT=3000

# Auth token for API + WebSocket access
# Generate with: openssl rand -hex 32
GAUNTLET_TOKEN=<your-secret-token-here>

# Phoenix Echo Gateway connection
# Gateway runs on Studio (100.68.34.116), NOT the VPS
# Use the appropriate URL depending on where the Gauntlet server runs:
#
#   If Gauntlet runs ON Studio (same machine as Gateway):
#     PHOENIX_ECHO_URL=http://localhost:18790
#
#   If Gauntlet runs on MacBook and reaches Studio via Tailscale:
#     PHOENIX_ECHO_URL=http://100.68.34.116:18790
#
#   VPS (legacy — no longer active for Gateway):
#     PHOENIX_ECHO_URL=https://echo.phoenixelectric.life
#
PHOENIX_ECHO_URL=http://100.68.34.116:18790
PHOENIX_GATEWAY_TOKEN=

# Agent CLI paths (defaults to /opt/homebrew/bin/)
# Uncomment and set if your CLIs are elsewhere:
# CLAUDE_PATH=/opt/homebrew/bin/claude
# GEMINI_PATH=/opt/homebrew/bin/gemini
# CODEX_PATH=/opt/homebrew/bin/codex

# LEDGER paths (defaults to ~/Phoenix_Local/_GATEWAY/)
# GATEWAY_PATH=/path/to/gateway
# GAUNTLET_LEDGER=/path/to/GAUNTLET_SESSION_LEDGER.md
# UNIFIED_PROD_PATH=/path/to/PHOENIX_UNIFIED_PROD_REPO
# AGENT_BRIDGE_LEDGER=/path/to/AGENT_BRIDGE_LEDGER.md
# SHARED_OPS_LEDGER=/path/to/SHARED_OPS_LEDGER.md

# Optional working directories per local agent
# GAUNTLET_WORKDIR=/Users/shanewarehime
# ECHO_PRO_CWD=/Users/shanewarehime
# GEMINI_CWD=/Users/shanewarehime
# CODEX_CWD=/Users/shanewarehime
